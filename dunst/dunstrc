[global]
    ### Display ###
    monitor = 0
    follow = mouse

    ### Geometry ###
    width = 320
    height = (0, 120)
    origin = top-right
    offset = (10, 20)
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 3
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### Appearance ###
    transparency = 0
    separator_height = 1
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 10
    frame_width = 2
    gap_size = 6
    separator_color = frame
    sort = yes

    ### Text ###
    font = JetBrains Mono 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 20
    max_icon_size = 32

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc ###
    dmenu = /usr/bin/rofi -dmenu -p dunst
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 0
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#000000bb"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 4
    #icon = /path/to/icon

[urgency_normal]
    background = "#000000bb"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 6

[urgency_critical]
    background = "#000000bb"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 0
    #icon = /path/to/icon
